# ═══════════════════════════════════════════════
# Clara AI Pipeline — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# All LLM providers have free tiers.
# ═══════════════════════════════════════════════

# ─── PRIMARY LLM (Mistral) ─────────────────────
# Get free key at: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_key_here
MISTRAL_MODEL=mistral-medium-2505
MISTRAL_FALLBACK_MODEL=mistral-small-2506

# ─── FALLBACK LLM (Groq) ───────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ─── FALLBACK LLM (Gemini) ─────────────────────
# Get free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# ─── SUPABASE DATABASE ─────────────────────────
# Get from: supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ─── AIRTABLE TASK TRACKER ─────────────────────
# Get from: airtable.com/create/tokens
# Scopes: data.records:read, data.records:write
AIRTABLE_API_KEY=your_airtable_key_here
AIRTABLE_BASE_ID=appXXXXXXXXXX
AIRTABLE_TABLE_NAME=Clara_Accounts

# ─── RETELL AI ─────────────────────────────────
# Get from: retell.ai → Settings → API Keys
RETELL_API_KEY=your_retell_key_here

# ─── PIPELINE SETTINGS ─────────────────────────
# Which LLM provider to prioritize (mistral/gemini/groq)
PRIMARY_LLM=mistral
# Save local JSON copies even when Supabase works
ENABLE_LOCAL_FALLBACK=true
# Max retries per LLM attempt
LLM_MAX_RETRIES=3
# Base delay between retries (seconds)
LLM_RETRY_DELAY=2

# ─── PATHS ─────────────────────────────────────
DATA_DIR=./data
OUTPUT_DIR=./outputs
LOG_DIR=./logs
PROMPTS_DIR=./prompts
SCHEMAS_DIR=./schemas
