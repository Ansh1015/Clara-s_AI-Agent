{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "account_id": { "type": "string" },
    "company_name": { "type": "string" },
    "business_hours": {
      "type": "object",
      "properties": {
        "days": { "type": ["string", "null"] },
        "start": { "type": ["string", "null"] },
        "end": { "type": ["string", "null"] },
        "timezone": { "type": ["string", "null"] }
      }
    },
    "office_address": { "type": ["string", "null"] },
    "services_supported": { "type": "array", "items": { "type": "string" } },
    "emergency_definition": { "type": "array", "items": { "type": "string" } },
    "emergency_routing_rules": {
      "type": "object",
      "properties": {
        "primary_contact": { "type": ["string", "null"] },
        "primary_phone": { "type": ["string", "null"] },
        "routing_order": { "type": "array", "items": { "type": "string" } },
        "fallback_action": { "type": ["string", "null"] }
      }
    },
    "non_emergency_routing_rules": {
      "type": "object",
      "properties": {
        "action": { "type": ["string", "null"] },
        "details": { "type": ["string", "null"] }
      }
    },
    "call_transfer_rules": {
      "type": "object",
      "properties": {
        "timeout_seconds": { "type": ["number", "null"] },
        "retries": { "type": ["number", "null"] },
        "message_on_fail": { "type": ["string", "null"] }
      }
    },
    "integration_constraints": { "type": "array", "items": { "type": "string" } },
    "after_hours_flow_summary": { "type": ["string", "null"] },
    "office_hours_flow_summary": { "type": ["string", "null"] },
    "questions_or_unknowns": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": ["string", "null"] },
    "source": { "type": "string" },
    "version": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "required": [
    "account_id",
    "company_name",
    "version",
    "source",
    "created_at"
  ]
}
