          "name": "Mistral API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Error handler for Mistral — Regenerate Agent Spec v2\nconst items = $input.all();\nfor (const item of items) {\n  if (item.json.error || (item.json.statusCode && item.json.statusCode >= 400)) {\n    const msg = `[${new Date().toISOString()}] Mistral — Regenerate Agent Spec v2 FAILED: ${JSON.stringify(item.json.error || item.json)}\\n`;\n    console.error(msg);\n    // Continue execution — don't block the pipeline\n  }\n}\nreturn items;"
      },
      "id": "50338022-b0b0-4d66-90c3-a9045676ef77",
      "name": "Error Handler: Regenerate Agent Spec v2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1650,
        1000
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "\nconst patch = $('Function: Merge Patch').first().json.patch;\nconst accountId = $('Function: Merge Patch').first().json.account_id;\n\nconst changes = {\n  account_id: accountId,\n  updated_fields: patch.updated_fields || {},\n  new_fields: patch.new_fields || {},\n  resolved_unknowns: patch.resolved_unknowns || [],\n  created_at: new Date().toISOString()\n};\n\n// Generate markdown summary\nlet md = '# Changelog: ' + accountId + '\\n\\n';\nmd += '## Updated Fields\\n';\nfor (const [k, v] of Object.entries(changes.updated_fields)) {\n  md += '- **' + k + '**: ' + JSON.stringify(v) + '\\n';\n}\nmd += '\\n## New Fields\\n';\nfor (const [k, v] of Object.entries(changes.new_fields)) {\n  md += '- **' + k + '**: ' + JSON.stringify(v) + '\\n';\n}\n\nreturn [{ json: { changes: changes, changelog_md: md, account_id: accountId } }];\n"
      },
