      "id": "7d190396-9910-410a-b6c6-fb26baa341e6",
      "name": "HTTP Request: Supabase — Load v1 Memo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        650,
        800
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "supabase_api",
          "name": "Supabase API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "\nconst fs = require('fs');\nconst accountId = $json.account_id || $('Set Account ID B').first().json.account_id;\nconst filePath = 'data/onboarding/' + accountId + '_onboarding.txt';\nconst transcript = fs.readFileSync(filePath, 'utf-8');\n\n// Get v1 memo from Supabase response\nconst supabaseResp = $('HTTP Request: Supabase — Load v1 Memo').first().json;\nlet v1Memo = {};\nif (Array.isArray(supabaseResp) && supabaseResp.length > 0) {\n  v1Memo = supabaseResp[0].memo || {};\n} else if (supabaseResp.memo) {\n  v1Memo = supabaseResp.memo;\n}\n\nreturn [{ json: { account_id: accountId, transcript: transcript, v1_memo: v1Memo } }];\n"
      },
      "id": "713619ab-30f0-4bb1-9c07-1581e8279387",
      "name": "Read Onboarding Transcript",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        800
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.mistral.ai/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"model\": \"mistral-medium-2505\", \"response_format\": {\"type\": \"json_object\"}, \"messages\": [{\"role\": \"system\", \"content\": \"You are a data extraction AI. Compare this onboarding transcript against the existing v1 memo and extract a patch of new or changed information. Return valid JSON only.\"},{\"role\": \"user\", \"content\": JSON.stringify({v1_memo: $json.v1_memo, transcript: $json.transcript})}] }",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "0e758a74-acc4-48d8-9616-76c0fbcc3add",
      "name": "HTTP Request: Mistral — Extract Patch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1050,
        800
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "mistral_api",
          "name": "Mistral API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Error handler for Mistral — Extract Patch\nconst items = $input.all();\nfor (const item of items) {\n  if (item.json.error || (item.json.statusCode && item.json.statusCode >= 400)) {\n    const msg = `[${new Date().toISOString()}] Mistral — Extract Patch FAILED: ${JSON.stringify(item.json.error || item.json)}\\n`;\n    console.error(msg);\n    // Continue execution — don't block the pipeline\n  }\n}\nreturn items;"
      },
      "id": "2f3d1365-8d00-4581-9309-40ec549184b5",
      "name": "Error Handler: Extract Patch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        1000
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "\nconst data = $json;\nlet patch;\nif (data.choices && data.choices[0]) {\n  patch = JSON.parse(data.choices[0].message.content);\n} else {\n  patch = data;\n}\n\nconst v1Memo = $('Read Onboarding Transcript').first().json.v1_memo;\nconst accountId = $('Read Onboarding Transcript').first().json.account_id;\n\n// Deep merge patch onto v1 memo\nconst v2Memo = { ...v1Memo };\nconst updated = patch.updated_fields || {};\nconst newFields = patch.new_fields || {};\n\nfor (const [key, val] of Object.entries(updated)) {\n  v2Memo[key] = val;\n}\nfor (const [key, val] of Object.entries(newFields)) {\n  v2Memo[key] = val;\n}\n\nv2Memo.version = 'v2';\nv2Memo.account_id = accountId;\nv2Memo.source = 'onboarding_call';\nv2Memo.created_at = new Date().toISOString();\n\nreturn [{ json: { v2_memo: v2Memo, patch: patch, account_id: accountId } }];\n"
      },
      "id": "34a07c5b-0df8-4938-a7d7-a54493c42a91",
      "name": "Function: Merge Patch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        800
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst v2Memo = $json.v2_memo;\n// Basic validation — ensure required fields\nif (!v2Memo.account_id || !v2Memo.company_name) {\n  throw new Error('v2 memo missing required fields');\n}\nreturn [{ json: v2Memo }];\n"
      },
      "id": "3e22d44b-8bbb-4518-8efa-1458401feb1c",
      "name": "Function: Validate v2 Memo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1450,
        800
      ]
