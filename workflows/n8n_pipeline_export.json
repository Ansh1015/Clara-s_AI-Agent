    {
      "parameters": {
        "jsCode": "\nconst fs = require('fs');\nconst path = require('path');\nconst accountId = $('Function: Validate Memo').first().json.account_id;\nconst outDir = 'outputs/accounts/' + accountId + '/v1';\n\n// Create directory\nfs.mkdirSync(outDir, { recursive: true });\n\n// Save memo\nconst memo = $('Function: Validate Memo').first().json;\nfs.writeFileSync(path.join(outDir, 'account_memo.json'), JSON.stringify(memo, null, 2));\n\n// Save spec\nconst spec = $('Function: Validate Agent Spec').first().json;\nfs.writeFileSync(path.join(outDir, 'agent_spec.json'), JSON.stringify(spec, null, 2));\n\nreturn [{ json: { account_id: accountId, status: 'files_saved', version: 'v1', pipeline: 'A', company_name: memo.company_name || '' } }];\n"
      },
