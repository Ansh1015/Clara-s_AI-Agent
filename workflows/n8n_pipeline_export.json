              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"model\": \"mistral-medium-2505\", \"response_format\": {\"type\": \"json_object\"}, \"messages\": [{\"role\": \"system\", \"content\": \"You are an AI agent configuration generator. Generate a Retell AI agent spec from this v2 account memo. Return valid JSON only.\"},{\"role\": \"user\", \"content\": JSON.stringify($json)}] }",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
