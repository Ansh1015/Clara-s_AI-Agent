        "jsCode": "// Error handler for Mistral — Extract Memo\nconst items = $input.all();\nfor (const item of items) {\n  if (item.json.error || (item.json.statusCode && item.json.statusCode >= 400)) {\n    const msg = `[${new Date().toISOString()}] Mistral — Extract Memo FAILED: ${JSON.stringify(item.json.error || item.json)}\\n`;\n    console.error(msg);\n    // Continue execution — don't block the pipeline\n  }\n}\nreturn items;"
